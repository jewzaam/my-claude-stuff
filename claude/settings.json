  "hooks": {
    "PostToolUse": [
      {
        "hooks": [
          {
            "command": "python3 ~/.claude/my-claude-stuff/scripts/prompt_log.py",
            "type": "command"
          }
        ],
        "matcher": "AskUserQuestion"
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "command": "python3 ~/.claude/my-claude-stuff/scripts/block_commands.py",
            "type": "command"
          }
        ],
        "matcher": "Bash"
      },
      {
        "hooks": [
          {
            "command": "python3 ~/.claude/my-claude-stuff/scripts/block_paths.py",
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "command": "python3 ~/.claude/my-claude-stuff/scripts/prompt_log.py",
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "command": "python3 ~/.claude/my-claude-stuff/scripts/prompt_log.py",
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ]
  },
